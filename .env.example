# Frontend (Vite) — safe to expose, this is the public anon key
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-public-key

# Used only by supabase/seed.mjs (Node script) — NEVER put the service role
# key in VITE_ variables, it would be bundled into the frontend and exposed.
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
